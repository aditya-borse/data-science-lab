     ]
    }
   ],
   "source": [
    "data = { 'a': [10, 20, 30, 1000], 'b': [5, 15, 25, 200] }\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "Q1 = df.quantile(0.25)\n",
    "Q3 = df.quantile(0.75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
    "outlier = ((df < (Q1 - 1.5*IQR)) | (df > (Q3 + 1.5*IQR))).any(axis=1)\n",
    "print(outlier)"
   ]
  }
 ],
